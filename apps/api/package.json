{
  "name": "@taskflow/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "nest start",
    "start:prod": "node dist/main.js",
    "test:tenant-isolation": "tsx src/common/tests/tenant-isolation.test.ts",
    "test:tasks-core": "tsx src/tasks/tests/tasks-core.test.ts",
    "test:leave-requests-core": "tsx src/leave-requests/tests/leave-requests-core.test.ts",
    "test:leave-enhancements": "tsx src/leave-requests/tests/leave-enhancements.test.ts",
    "test:leave-balances": "tsx src/leave-requests/tests/leave-balances.test.ts",
    "test:calendar": "tsx src/leave-requests/tests/leave-calendar.test.ts",
    "test:permissions": "tsx src/leave-requests/tests/leave-permissions.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"../../prisma/**/*.ts\"",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@prisma/client": "^6.10.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.79.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.11.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
