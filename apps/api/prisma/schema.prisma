generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  AR @map("ar")
  EN @map("en")

  @@map("locale")
}

enum CompanyPlan {
  STARTER      @map("starter")
  PROFESSIONAL @map("professional")
  ENTERPRISE   @map("enterprise")

  @@map("company_plan")
}

enum CompanyStatus {
  ACTIVE    @map("active")
  TRIAL     @map("trial")
  SUSPENDED @map("suspended")

  @@map("company_status")
}

enum UserStatus {
  ACTIVE    @map("active")
  INACTIVE  @map("inactive")
  INVITED   @map("invited")
  SUSPENDED @map("suspended")

  @@map("user_status")
}

enum SystemRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  MANAGER
  EMPLOYEE

  @@map("system_role")
}

enum TaskStatus {
  NEW         @map("new")
  ASSIGNED    @map("assigned")
  IN_PROGRESS @map("in_progress")
  PENDING     @map("pending")
  COMPLETED   @map("completed")
  CANCELLED   @map("cancelled")

  @@map("task_status")
}

enum TaskPriority {
  LOW      @map("low")
  MEDIUM   @map("medium")
  HIGH     @map("high")
  CRITICAL @map("critical")

  @@map("task_priority")
}

enum LeaveStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  CANCELLED @map("cancelled")

  @@map("leave_status")
}

enum EmailDirection {
  INBOUND  @map("inbound")
  OUTBOUND @map("outbound")

  @@map("email_direction")
}

enum EntityType {
  TASK
  EMAIL
  LEAVE_REQUEST
  EMPLOYEE
  USER
  DEPARTMENT
  COMPANY
  CLIENT

  @@map("entity_type")
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_COMPLETED
  TASK_DUE_SOON
  TASK_OVERDUE
  LEAVE_SUBMITTED
  LEAVE_APPROVED
  LEAVE_REJECTED
  LEAVE_CANCELLED
  EMAIL_SENT
  SYSTEM

  @@map("notification_type")
}

enum SmtpEncryption {
  NONE     @map("none")
  STARTTLS @map("starttls")
  SSL_TLS  @map("ssl_tls")

  @@map("smtp_encryption")
}

enum ApprovalActionStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  CANCELLED @map("cancelled")

  @@map("approval_action_status")
}

enum ThemePreference {
  SYSTEM @map("system")
  LIGHT  @map("light")
  DARK   @map("dark")

  @@map("theme_preference")
}

model Company {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  slug          String        @unique
  plan          CompanyPlan   @default(STARTER)
  status        CompanyStatus @default(TRIAL)
  defaultLocale Locale        @default(AR) @map("default_locale")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz(6)

  users           User[]
  departments     Department[]
  roles           Role[]
  permissions     Permission[]
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  auditLogs       AuditLog[]
  activities      Activity[]
  refreshTokens   RefreshToken[]
  tasks           Task[]
  taskAssignees   TaskAssignee[]
  taskWatchers    TaskWatcher[]
  leaveTypes      LeaveType[]
  leaveRequests   LeaveRequest[]
  emailMessages   EmailMessage[]
  attachments     Attachment[]
  comments        Comment[]
  notifications   Notification[]
  searchIndexes   SearchIndex[]
  smtpSetting     SmtpSetting?
  approvalWorkflows ApprovalWorkflow[]
  approvalSteps   ApprovalStep[]
  approvalActions ApprovalAction[]
  tags            Tag[]
  entityTags      EntityTag[]
  userPreferences UserPreference[]

  @@map("companies")
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String     @map("company_id") @db.Uuid
  departmentId String?    @map("department_id") @db.Uuid
  email        String
  passwordHash String     @map("password_hash")
  name         String
  jobTitle     String?    @map("job_title")
  locale       Locale     @default(AR)
  status       UserStatus @default(INVITED)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)

  company            Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  department         Department?    @relation("DepartmentUsers", fields: [departmentId], references: [id], onDelete: SetNull)
  managedDepartments Department[]   @relation("DepartmentManager")
  userRoles          UserRole[]
  auditLogs          AuditLog[]
  activities         Activity[]
  refreshTokens      RefreshToken[]
  createdTasks       Task[]         @relation("TaskCreator")
  assignedTasks      TaskAssignee[]
  watchedTasks       TaskWatcher[]
  leaveRequests      LeaveRequest[]
  sentEmails         EmailMessage[] @relation("EmailSender")
  uploadedAttachments Attachment[]  @relation("AttachmentUploader")
  comments           Comment[]      @relation("CommentAuthor")
  notifications      Notification[] @relation("NotificationUser")
  approvalSteps      ApprovalStep[] @relation("ApprovalStepApproverUser")
  approvalActions    ApprovalAction[] @relation("ApprovalActionActor")
  createdTags        Tag[]          @relation("TagCreator")
  createdEntityTags  EntityTag[]    @relation("EntityTagCreator")
  preference         UserPreference?

  @@unique([companyId, email])
  @@index([companyId])
  @@index([departmentId])
  @@map("users")
}

model Role {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String     @map("company_id") @db.Uuid
  name        String
  systemName  SystemRole @map("system_name")
  description String?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  approvalSteps   ApprovalStep[]   @relation("ApprovalStepApproverRole")

  @@unique([companyId, systemName])
  @@index([companyId])
  @@map("roles")
}

model Permission {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  action      String
  subject     String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]

  @@unique([companyId, action, subject])
  @@index([companyId])
  @@map("permissions")
}

model UserRole {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, roleId])
  @@index([companyId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  permissionId String    @map("permission_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([companyId, roleId, permissionId])
  @@index([companyId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Department {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  managerId   String?   @map("manager_id") @db.Uuid
  name        String
  code        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  company       Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  manager       User?   @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  users         User[]  @relation("DepartmentUsers")
  tasks         Task[]
  leaveRequests LeaveRequest[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([managerId])
  @@map("departments")
}

model AuditLog {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String    @map("company_id") @db.Uuid
  actorId    String?   @map("actor_id") @db.Uuid
  action     String
  entityType String    @map("entity_type")
  entityId   String?   @map("entity_id") @db.Uuid
  metadata   Json      @default("{}")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([actorId])
  @@map("audit_logs")
}

model Activity {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  actorId   String?   @map("actor_id") @db.Uuid
  type      String
  title     String
  titleAr   String?   @map("title_ar")
  metadata  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([actorId])
  @@map("activities")
}

model RefreshToken {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @map("token_hash")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@map("refresh_tokens")
}

model Task {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String       @map("company_id") @db.Uuid
  departmentId String?      @map("department_id") @db.Uuid
  createdById  String?      @map("created_by_id") @db.Uuid
  taskNumber   String       @map("task_number")
  title        String
  description  String?
  status       TaskStatus   @default(NEW)
  priority     TaskPriority @default(MEDIUM)
  dueAt        DateTime?    @map("due_at") @db.Timestamptz(6)
  completedAt  DateTime?    @map("completed_at") @db.Timestamptz(6)
  reminderSentAt DateTime?  @map("reminder_sent_at") @db.Timestamptz(6)
  estimatedHours Decimal?   @map("estimated_hours") @db.Decimal(8, 2)
  actualHours    Decimal?   @map("actual_hours") @db.Decimal(8, 2)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?    @map("deleted_at") @db.Timestamptz(6)

  company    Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  department Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy  User?          @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignees  TaskAssignee[]
  watchers   TaskWatcher[]

  @@unique([companyId, taskNumber])
  @@index([companyId, status])
  @@index([companyId, priority])
  @@index([companyId, dueAt])
  @@index([departmentId])
  @@map("tasks")
}

model TaskAssignee {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  taskId    String    @map("task_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, taskId, userId])
  @@index([companyId])
  @@index([taskId])
  @@index([userId])
  @@map("task_assignees")
}

model TaskWatcher {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  taskId    String    @map("task_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, taskId, userId])
  @@index([companyId])
  @@index([taskId])
  @@index([userId])
  @@map("task_watchers")
}

model LeaveRequest {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String      @map("company_id") @db.Uuid
  employeeId   String      @map("employee_id") @db.Uuid
  departmentId String?     @map("department_id") @db.Uuid
  leaveTypeId  String?     @map("leave_type_id") @db.Uuid
  leaveType    String      @map("leave_type")
  startsAt     DateTime    @map("starts_at") @db.Timestamptz(6)
  endsAt       DateTime    @map("ends_at") @db.Timestamptz(6)
  status       LeaveStatus @default(PENDING)
  reason       String?
  submittedAt  DateTime    @default(now()) @map("submitted_at") @db.Timestamptz(6)
  approvedAt   DateTime?   @map("approved_at") @db.Timestamptz(6)
  rejectedAt   DateTime?   @map("rejected_at") @db.Timestamptz(6)
  cancelledAt  DateTime?   @map("cancelled_at") @db.Timestamptz(6)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz(6)

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee   User        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  leaveTypeRef LeaveType? @relation(fields: [leaveTypeId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([companyId, leaveTypeId])
  @@index([employeeId])
  @@map("leave_requests")
}

model LeaveType {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId           String    @map("company_id") @db.Uuid
  name                String
  code                String
  description         String?
  isPaid              Boolean   @default(true) @map("is_paid")
  annualAllowanceDays Int?      @map("annual_allowance_days")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  leaveRequests LeaveRequest[]

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("leave_types")
}

model EmailMessage {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String         @map("company_id") @db.Uuid
  senderId    String?        @map("sender_id") @db.Uuid
  direction   EmailDirection
  subject     String
  body        String
  fromAddress String         @map("from_address")
  toAddresses Json           @map("to_addresses")
  readAt      DateTime?      @map("read_at") @db.Timestamptz(6)
  sentAt      DateTime?      @map("sent_at") @db.Timestamptz(6)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  sender  User?   @relation("EmailSender", fields: [senderId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([senderId])
  @@map("email_messages")
}

model Attachment {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String     @map("company_id") @db.Uuid
  entityType   EntityType @map("entity_type")
  entityId     String     @map("entity_id") @db.Uuid
  fileName     String     @map("file_name")
  filePath     String     @map("file_path")
  mimeType     String     @map("mime_type")
  fileSize     Int        @map("file_size")
  uploadedById String?    @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)

  company    Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  uploadedBy User?   @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([companyId, entityType, entityId])
  @@index([uploadedById])
  @@map("attachments")
}

model Comment {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String     @map("company_id") @db.Uuid
  entityType EntityType @map("entity_type")
  entityId   String     @map("entity_id") @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  content    String     @db.Text
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime?  @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User    @relation("CommentAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, entityType, entityId, createdAt])
  @@index([userId])
  @@map("comments")
}

model Notification {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String           @map("company_id") @db.Uuid
  userId     String           @map("user_id") @db.Uuid
  type       NotificationType
  title      String
  message    String
  entityType EntityType?      @map("entity_type")
  entityId   String?          @map("entity_id") @db.Uuid
  isRead     Boolean          @default(false) @map("is_read")
  readAt     DateTime?        @map("read_at") @db.Timestamptz(6)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime?        @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User    @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId, userId, isRead, createdAt])
  @@index([companyId, entityType, entityId])
  @@map("notifications")
}

model SearchIndex {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String     @map("company_id") @db.Uuid
  entityType EntityType @map("entity_type")
  entityId   String     @map("entity_id") @db.Uuid
  title      String
  content    String     @db.Text
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime?  @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, entityType, entityId])
  @@index([companyId, title])
  @@map("search_index")
}

model SmtpSetting {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId         String         @unique @map("company_id") @db.Uuid
  host              String
  port              Int
  username          String?
  passwordEncrypted String?        @map("password_encrypted") @db.Text
  encryption        SmtpEncryption @default(STARTTLS)
  fromName          String         @map("from_name")
  fromEmail         String         @map("from_email")
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?      @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@map("smtp_settings")
}

model ApprovalWorkflow {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String         @map("company_id") @db.Uuid
  entityType  EntityType     @map("entity_type")
  name        String
  description String?
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz(6)

  company Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  steps   ApprovalStep[]
  actions ApprovalAction[]

  @@index([companyId, entityType, isActive])
  @@map("approval_workflows")
}

model ApprovalStep {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String    @map("company_id") @db.Uuid
  workflowId     String    @map("workflow_id") @db.Uuid
  stepOrder      Int       @map("step_order")
  name           String
  approverRoleId String?   @map("approver_role_id") @db.Uuid
  approverUserId String?   @map("approver_user_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  company      Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  workflow     ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  approverRole Role?            @relation("ApprovalStepApproverRole", fields: [approverRoleId], references: [id], onDelete: SetNull)
  approverUser User?            @relation("ApprovalStepApproverUser", fields: [approverUserId], references: [id], onDelete: SetNull)
  actions      ApprovalAction[]

  @@unique([companyId, workflowId, stepOrder])
  @@index([companyId])
  @@index([approverRoleId])
  @@index([approverUserId])
  @@map("approval_steps")
}

model ApprovalAction {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String               @map("company_id") @db.Uuid
  workflowId String               @map("workflow_id") @db.Uuid
  stepId     String?              @map("step_id") @db.Uuid
  entityType EntityType           @map("entity_type")
  entityId   String               @map("entity_id") @db.Uuid
  actorId    String?              @map("actor_id") @db.Uuid
  status     ApprovalActionStatus @default(PENDING)
  comment    String?              @db.Text
  metadata   Json                 @default("{}")
  createdAt  DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime?            @map("deleted_at") @db.Timestamptz(6)

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  step     ApprovalStep?    @relation(fields: [stepId], references: [id], onDelete: SetNull)
  actor    User?            @relation("ApprovalActionActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, entityType, entityId])
  @@index([workflowId])
  @@index([stepId])
  @@index([actorId])
  @@map("approval_actions")
}

model Tag {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  name        String
  color       String?
  createdById String?   @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  createdBy  User?       @relation("TagCreator", fields: [createdById], references: [id], onDelete: SetNull)
  entityTags EntityTag[]

  @@unique([companyId, name])
  @@index([companyId])
  @@index([createdById])
  @@map("tags")
}

model EntityTag {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String     @map("company_id") @db.Uuid
  tagId       String     @map("tag_id") @db.Uuid
  entityType  EntityType @map("entity_type")
  entityId    String     @map("entity_id") @db.Uuid
  createdById String?    @map("created_by_id") @db.Uuid
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)

  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("EntityTagCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([companyId, tagId, entityType, entityId])
  @@index([companyId, entityType, entityId])
  @@index([tagId])
  @@index([createdById])
  @@map("entity_tags")
}

model UserPreference {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId        String          @map("company_id") @db.Uuid
  userId           String          @unique @map("user_id") @db.Uuid
  language         Locale          @default(AR)
  theme            ThemePreference @default(SYSTEM)
  sidebarCollapsed Boolean         @default(false) @map("sidebar_collapsed")
  dashboardLayout  Json            @default("{}") @map("dashboard_layout")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?       @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@map("user_preferences")
}
