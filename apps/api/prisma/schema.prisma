  usersCount         Int       @default(0) @map("users_count")
  activeUsersCount   Int       @default(0) @map("active_users_count")
  tasksCount         Int       @default(0) @map("tasks_count")
  openTasksCount     Int       @default(0) @map("open_tasks_count")
  leaveRequestsCount Int       @default(0) @map("leave_requests_count")
  emailsSentCount    Int       @default(0) @map("emails_sent_count")
  storageBytes       BigInt    @default(0) @map("storage_bytes")
  metadata           Json      @default("{}")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([companyId, periodStart, periodEnd])
  @@index([companyId, periodEnd])
  @@map("platform_usage_snapshots")
}

model CompanySwitchSession {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId      String              @map("company_id") @db.Uuid
  actorCompanyId String              @map("actor_company_id") @db.Uuid
  actorUserId    String              @map("actor_user_id") @db.Uuid
  status         CompanySwitchStatus @default(ACTIVE)
  reason         String?
  startedAt      DateTime            @default(now()) @map("started_at") @db.Timestamptz(6)
  expiresAt      DateTime            @map("expires_at") @db.Timestamptz(6)
  endedAt        DateTime?           @map("ended_at") @db.Timestamptz(6)
  revokedAt      DateTime?           @map("revoked_at") @db.Timestamptz(6)
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?           @map("deleted_at") @db.Timestamptz(6)

  targetCompany Company @relation("CompanySwitchTarget", fields: [companyId], references: [id], onDelete: Restrict)
  actorCompany  Company @relation("CompanySwitchActorCompany", fields: [actorCompanyId], references: [id], onDelete: Restrict)
  actorUser     User    @relation("CompanySwitchActor", fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([actorUserId, status])
  @@index([expiresAt])
  @@map("company_switch_sessions")
}

model PlatformSetting {
  id          String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key         String                   @unique
  value       Json
  valueType   PlatformSettingValueType @default(STRING) @map("value_type")
  description String?
  isSecret    Boolean                  @default(false) @map("is_secret")
  createdAt   DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?                @map("deleted_at") @db.Timestamptz(6)

  @@index([valueType])
  @@map("platform_settings")
}
