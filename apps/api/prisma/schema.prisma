generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  AR @map("ar")
  EN @map("en")

  @@map("locale")
}

enum CompanyPlan {
  STARTER      @map("starter")
  PROFESSIONAL @map("professional")
  ENTERPRISE   @map("enterprise")

  @@map("company_plan")
}

enum CompanyStatus {
  ACTIVE    @map("active")
  TRIAL     @map("trial")
  SUSPENDED @map("suspended")

  @@map("company_status")
}

enum SubscriptionStatus {
  TRIALING  @map("trialing")
  ACTIVE    @map("active")
  PAST_DUE  @map("past_due")
  CANCELLED @map("cancelled")
  EXPIRED   @map("expired")

  @@map("subscription_status")
}

enum BillingInterval {
  MONTHLY @map("monthly")
  YEARLY  @map("yearly")

  @@map("billing_interval")
}

enum SubscriptionInvoiceStatus {
  DRAFT         @map("draft")
  OPEN          @map("open")
  PAID          @map("paid")
  VOID          @map("void")
  UNCOLLECTIBLE @map("uncollectible")

  @@map("subscription_invoice_status")
}

enum CompanySwitchStatus {
  ACTIVE  @map("active")
  ENDED   @map("ended")
  REVOKED @map("revoked")
  EXPIRED @map("expired")

  @@map("company_switch_status")
}

enum PlatformSettingValueType {
  STRING  @map("string")
  NUMBER  @map("number")
  BOOLEAN @map("boolean")
  JSON    @map("json")
  SECRET  @map("secret")

  @@map("platform_setting_value_type")
}

enum UserStatus {
  ACTIVE    @map("active")
  INACTIVE  @map("inactive")
  INVITED   @map("invited")
  SUSPENDED @map("suspended")

  @@map("user_status")
}

enum SystemRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  MANAGER
  EMPLOYEE

  @@map("system_role")
}

enum TaskStatus {
  NEW         @map("new")
  ASSIGNED    @map("assigned")
  IN_PROGRESS @map("in_progress")
  PENDING     @map("pending")
  COMPLETED   @map("completed")
  CANCELLED   @map("cancelled")

  @@map("task_status")
}

enum TaskPriority {
  LOW      @map("low")
  MEDIUM   @map("medium")
  HIGH     @map("high")
  CRITICAL @map("critical")

  @@map("task_priority")
}

enum LeaveStatus {
  PENDING        @map("pending")
  INFO_REQUESTED @map("info_requested")
  APPROVED       @map("approved")
  REJECTED       @map("rejected")
  CANCELLED      @map("cancelled")

  @@map("leave_status")
}

enum LeaveDurationType {
  FULL_DAY    @map("full_day")
  HALF_DAY    @map("half_day")
  HALF_DAY_AM @map("half_day_am")
  HALF_DAY_PM @map("half_day_pm")
  HOURS       @map("hours")

  @@map("leave_duration_type")
}

enum LeaveRequestType {
  LEAVE      @map("leave")
  PERMISSION @map("permission")

  @@map("leave_request_type")
}

enum LeaveHalfDayPeriod {
  MORNING   @map("morning")
  AFTERNOON @map("afternoon")

  @@map("leave_half_day_period")
}

enum LeaveApprovalMode {
  MANAGER_ONLY @map("manager_only")
  MANAGER_HR   @map("manager_hr")

  @@map("leave_approval_mode")
}

enum EmailDirection {
  INBOUND  @map("inbound")
  OUTBOUND @map("outbound")

  @@map("email_direction")
}

enum EmailStatus {
  DRAFT     @map("draft")
  QUEUED    @map("queued")
  SENDING   @map("sending")
  SENT      @map("sent")
  FAILED    @map("failed")
  CANCELLED @map("cancelled")

  @@map("email_status")
}

enum EmailRecipientKind {
  TO  @map("to")
  CC  @map("cc")
  BCC @map("bcc")

  @@map("email_recipient_kind")
}

enum EmailRecipientType {
  EMPLOYEE @map("employee")
  CLIENT   @map("client")
  EXTERNAL @map("external")

  @@map("email_recipient_type")
}

enum EntityType {
  TASK
  EMAIL
  LEAVE_REQUEST
  EMPLOYEE
  USER
  DEPARTMENT
  COMPANY
  CLIENT

  @@map("entity_type")
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_COMPLETED
  TASK_DUE_SOON
  TASK_OVERDUE
  LEAVE_SUBMITTED
  LEAVE_INFO_REQUESTED
  LEAVE_APPROVED
  LEAVE_REJECTED
  LEAVE_CANCELLED
  EMAIL_QUEUED
  EMAIL_SENT
  EMAIL_FAILED
  SYSTEM

  @@map("notification_type")
}

enum SmtpEncryption {
  NONE     @map("none")
  STARTTLS @map("starttls")
  SSL_TLS  @map("ssl_tls")

  @@map("smtp_encryption")
}

enum ApprovalActionStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  CANCELLED @map("cancelled")

  @@map("approval_action_status")
}

enum ThemePreference {
  SYSTEM @map("system")
  LIGHT  @map("light")
  DARK   @map("dark")

  @@map("theme_preference")
}

model Company {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  slug          String        @unique
  plan          CompanyPlan   @default(STARTER)
  status        CompanyStatus @default(TRIAL)
  defaultLocale Locale        @default(AR) @map("default_locale")
  primaryDomain String?       @unique @map("primary_domain")
  billingEmail  String?       @map("billing_email")
  supportEmail  String?       @map("support_email")
  timezone      String        @default("UTC")
  trialEndsAt   DateTime?     @map("trial_ends_at") @db.Timestamptz(6)
  suspendedAt   DateTime?     @map("suspended_at") @db.Timestamptz(6)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz(6)

  users           User[]
  departments     Department[]
  roles           Role[]
  permissions     Permission[]
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  auditLogs       AuditLog[]
  activities      Activity[]
  refreshTokens   RefreshToken[]
  tasks           Task[]
  taskAssignees   TaskAssignee[]
  taskWatchers    TaskWatcher[]
  leaveTypes      LeaveType[]
  leaveRequests   LeaveRequest[]
  leaveBalances   LeaveBalance[]
  leaveSetting    LeaveSetting?
  emails          Email[]
  emailRecipients EmailRecipient[]
  emailTemplates  EmailTemplate[]
  emailAttachments EmailAttachment[]
  emailMessages   EmailMessage[]
  attachments     Attachment[]
  comments        Comment[]
  notifications   Notification[]
  searchIndexes   SearchIndex[]
  savedFilters    SavedFilter[]
  recentSearches  RecentSearch[]
  smtpSetting     SmtpSetting?
  approvalWorkflows ApprovalWorkflow[]
  approvalSteps   ApprovalStep[]
  approvalActions ApprovalAction[]
  tags            Tag[]
  entityTags      EntityTag[]
  userPreferences UserPreference[]
  subscriptions   CompanySubscription[]
  subscriptionInvoices SubscriptionInvoice[]
  usageSnapshots  PlatformUsageSnapshot[]
  companySwitchSessions CompanySwitchSession[] @relation("CompanySwitchTarget")
  actorCompanySwitchSessions CompanySwitchSession[] @relation("CompanySwitchActorCompany")

  @@index([status])
  @@index([plan])
  @@index([trialEndsAt])
  @@map("companies")
}

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String     @map("company_id") @db.Uuid
  departmentId String?    @map("department_id") @db.Uuid
  managerId    String?    @map("manager_id") @db.Uuid
  email        String
  passwordHash String     @map("password_hash")
  name         String
  jobTitle     String?    @map("job_title")
  locale       Locale     @default(AR)
  status       UserStatus @default(INVITED)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)

  company            Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  department         Department?    @relation("DepartmentUsers", fields: [departmentId], references: [id], onDelete: SetNull)
  manager            User?          @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports      User[]         @relation("UserManager")
  managedDepartments Department[]   @relation("DepartmentManager")
  userRoles          UserRole[]
  auditLogs          AuditLog[]
  activities         Activity[]
  refreshTokens      RefreshToken[]
  createdTasks       Task[]         @relation("TaskCreator")
  assignedTasks      TaskAssignee[]
  watchedTasks       TaskWatcher[]
  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]
  createdEmails      Email[]       @relation("EmailCreator")
  emailRecipients    EmailRecipient[] @relation("EmailRecipientUser")
  createdEmailTemplates EmailTemplate[] @relation("EmailTemplateCreator")
  sentEmails         EmailMessage[] @relation("EmailSender")
  uploadedAttachments Attachment[]  @relation("AttachmentUploader")
  comments           Comment[]      @relation("CommentAuthor")
  notifications      Notification[] @relation("NotificationUser")
  approvalSteps      ApprovalStep[] @relation("ApprovalStepApproverUser")
  approvalActions    ApprovalAction[] @relation("ApprovalActionActor")
  createdTags        Tag[]          @relation("TagCreator")
  createdEntityTags  EntityTag[]    @relation("EntityTagCreator")
  preference         UserPreference?
  savedFilters       SavedFilter[]
  recentSearches     RecentSearch[]
  companySwitchSessions CompanySwitchSession[] @relation("CompanySwitchActor")

  @@unique([companyId, email])
  @@index([companyId])
  @@index([departmentId])
  @@index([managerId])
  @@index([companyId, managerId])
  @@map("users")
}

model Role {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String     @map("company_id") @db.Uuid
  name        String
  systemName  SystemRole @map("system_name")
  description String?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  approvalSteps   ApprovalStep[]   @relation("ApprovalStepApproverRole")

  @@unique([companyId, systemName])
  @@index([companyId])
  @@map("roles")
}

model Permission {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  action      String
  subject     String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]

  @@unique([companyId, action, subject])
  @@index([companyId])
  @@map("permissions")
}

model UserRole {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, roleId])
  @@index([companyId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String    @map("company_id") @db.Uuid
  roleId       String    @map("role_id") @db.Uuid
  permissionId String    @map("permission_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([companyId, roleId, permissionId])
  @@index([companyId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Department {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  managerId   String?   @map("manager_id") @db.Uuid
  name        String
  code        String
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  company       Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  manager       User?   @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  users         User[]  @relation("DepartmentUsers")
  tasks         Task[]
  leaveRequests LeaveRequest[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([managerId])
  @@map("departments")
}

model AuditLog {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String    @map("company_id") @db.Uuid
  actorId    String?   @map("actor_id") @db.Uuid
  action     String
  entityType String    @map("entity_type")
  entityId   String?   @map("entity_id") @db.Uuid
  metadata   Json      @default("{}")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([actorId])
  @@map("audit_logs")
}

model Activity {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  actorId   String?   @map("actor_id") @db.Uuid
  type      String
  title     String
  titleAr   String?   @map("title_ar")
  metadata  Json      @default("{}")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([actorId])
  @@map("activities")
}

model RefreshToken {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String    @map("company_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @map("token_hash")
  expiresAt   DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([userId])
  @@map("refresh_tokens")
}

model Task {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String       @map("company_id") @db.Uuid
  departmentId String?      @map("department_id") @db.Uuid
  createdById  String?      @map("created_by_id") @db.Uuid
  taskNumber   String       @map("task_number")
  title        String
  description  String?
  status       TaskStatus   @default(NEW)
  priority     TaskPriority @default(MEDIUM)
  dueAt        DateTime?    @map("due_at") @db.Timestamptz(6)
  completedAt  DateTime?    @map("completed_at") @db.Timestamptz(6)
  reminderSentAt DateTime?  @map("reminder_sent_at") @db.Timestamptz(6)
  estimatedHours Decimal?   @map("estimated_hours") @db.Decimal(8, 2)
  actualHours    Decimal?   @map("actual_hours") @db.Decimal(8, 2)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?    @map("deleted_at") @db.Timestamptz(6)

  company    Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  department Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdBy  User?          @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)
  assignees  TaskAssignee[]
  watchers   TaskWatcher[]

  @@unique([companyId, taskNumber])
  @@index([companyId, status])
  @@index([companyId, priority])
  @@index([companyId, dueAt])
  @@index([departmentId])
  @@map("tasks")
}

model TaskAssignee {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  taskId    String    @map("task_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, taskId, userId])
  @@index([companyId])
  @@index([taskId])
  @@index([userId])
  @@map("task_assignees")
}

model TaskWatcher {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String    @map("company_id") @db.Uuid
  taskId    String    @map("task_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  task    Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, taskId, userId])
  @@index([companyId])
  @@index([taskId])
  @@index([userId])
  @@map("task_watchers")
}

model LeaveRequest {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String      @map("company_id") @db.Uuid
  employeeId   String      @map("employee_id") @db.Uuid
  departmentId String?     @map("department_id") @db.Uuid
  leaveTypeId  String?     @map("leave_type_id") @db.Uuid
  requestNumber String?    @map("request_number")
  requestType  LeaveRequestType @default(LEAVE) @map("request_type")
  leaveType    String      @map("leave_type")
  startsAt     DateTime    @map("starts_at") @db.Timestamptz(6)
  endsAt       DateTime    @map("ends_at") @db.Timestamptz(6)
  startTime    DateTime?   @map("start_time") @db.Timestamptz(6)
  endTime      DateTime?   @map("end_time") @db.Timestamptz(6)
  durationType LeaveDurationType @default(FULL_DAY) @map("duration_type")
  durationDays Decimal     @default(1) @map("duration_days") @db.Decimal(5, 2)
  durationHours Decimal?   @map("duration_hours") @db.Decimal(5, 2)
  halfDayPeriod LeaveHalfDayPeriod? @map("half_day_period")
  status       LeaveStatus @default(PENDING)
  reason       String?
  submittedAt  DateTime    @default(now()) @map("submitted_at") @db.Timestamptz(6)
  infoRequestedAt DateTime? @map("info_requested_at") @db.Timestamptz(6)
  approvedAt   DateTime?   @map("approved_at") @db.Timestamptz(6)
  rejectedAt   DateTime?   @map("rejected_at") @db.Timestamptz(6)
  cancelledAt  DateTime?   @map("cancelled_at") @db.Timestamptz(6)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?   @map("deleted_at") @db.Timestamptz(6)

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee   User        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  leaveTypeRef LeaveType? @relation(fields: [leaveTypeId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([companyId, leaveTypeId])
  @@index([companyId, requestType])
  @@index([employeeId])
  @@unique([companyId, requestNumber])
  @@map("leave_requests")
}

model LeaveType {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId           String    @map("company_id") @db.Uuid
  name                String
  code                String
  description         String?
  isPaid              Boolean   @default(true) @map("is_paid")
  annualAllowanceDays Int?      @map("annual_allowance_days")
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt           DateTime? @map("deleted_at") @db.Timestamptz(6)

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]

  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("leave_types")
}

model LeaveBalance {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String    @map("company_id") @db.Uuid
  employeeId    String    @map("employee_id") @db.Uuid
  leaveTypeId   String    @map("leave_type_id") @db.Uuid
  allocatedDays Decimal   @default(0) @map("allocated_days") @db.Decimal(6, 2)
  usedDays      Decimal   @default(0) @map("used_days") @db.Decimal(6, 2)
