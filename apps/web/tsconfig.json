{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@taskflow/config": [
        "../../packages/config/src/index.ts"
      ],
      "@taskflow/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@taskflow/types": [
        "../../packages/types/src/index.ts"
      ],
      "@taskflow/ui/*": [
        "../../packages/ui/src/*"
      ]
    },
    "incremental": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
